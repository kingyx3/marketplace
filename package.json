{
  "name": "marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "TCG sealed-product marketplace with catalog, deals, preorders, and retail checkout",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:architecture": "vitest run tests/api-architecture.test.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "config:check": "node scripts/generate-environment-artifacts.mjs --check && node scripts/verify-vercel-config.mjs && node scripts/verify-supabase-config.mjs",
    "env:artifacts:write": "node scripts/generate-environment-artifacts.mjs --write",
    "env:check": "node scripts/generate-env.mjs --check",
    "env:write": "node scripts/generate-env.mjs --write",
    "env:resolve": "node scripts/resolve-environment.mjs",
    "env:config": "node scripts/environment-config.mjs",
    "db:bootstrap": "node scripts/bootstrap-database.mjs",
    "bootstrap": "node scripts/bootstrap-hosted.mjs",
    "bootstrap:doctor": "node scripts/bootstrap-local.mjs --check-only",
    "bootstrap:local": "node scripts/bootstrap-local.mjs",
    "bootstrap:github": "node scripts/configure-github-governance.mjs && node scripts/bootstrap-github.mjs",
    "bootstrap:github:apply": "node scripts/configure-github-governance.mjs --apply && node scripts/bootstrap-github.mjs --apply",
    "github:governance": "node scripts/configure-github-governance.mjs",
    "bootstrap:environment": "node scripts/bootstrap-environment.mjs",
    "bootstrap:verify": "node scripts/verify-environment.mjs",
    "runtime:reconcile": "node scripts/reconcile-runtime-environment.mjs",
    "providers:plan": "node scripts/configure-providers.mjs --plan",
    "providers:apply": "node scripts/configure-providers.mjs --apply",
    "providers:verify": "node scripts/configure-providers.mjs --verify",
    "verify:hosted:supabase": "node scripts/verify-hosted-supabase.mjs",
    "verify:hosted:oauth": "node scripts/verify-google-oauth-staging.mjs",
    "verify:hosted:stripe": "node scripts/verify-stripe-staging.mjs",
    "verify:hosted:providers": "node scripts/verify-supabase-provider-readiness.mjs",
    "verify:hosted:operations": "node scripts/verify-hosted-operations.mjs",
    "verify:hosted:restore": "bash scripts/verify-hosted-restore.sh"
  },
  "engines": {
    "node": ">=22.17.0 <23",
    "npm": ">=10.9.2 <11"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.66.0",
    "@stripe/react-stripe-js": "^6.8.0",
    "@stripe/stripe-js": "^9.10.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.2",
    "next": "^16.2.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "eslint": "9.39.2",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.1.7",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}

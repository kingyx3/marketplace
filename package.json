{
  "name": "marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "TCG booster box marketplace — B2C, B2B/wholesale, and pre-order distribution",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "config:check": "node scripts/verify-vercel-config.mjs && node scripts/verify-supabase-config.mjs",
    "env:check": "node scripts/generate-env.mjs --check",
    "env:write": "node scripts/generate-env.mjs --write",
    "env:resolve": "node scripts/resolve-environment.mjs",
    "env:config": "node scripts/environment-config.mjs",
    "bootstrap:environment": "node scripts/bootstrap-environment.mjs",
    "providers:plan": "node scripts/configure-providers.mjs --plan",
    "providers:apply": "node scripts/configure-providers.mjs --apply",
    "providers:verify": "node scripts/configure-providers.mjs --verify"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.49.4",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^18.1.0",
    "zod": "^3.24.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}

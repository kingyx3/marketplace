# Generated from config/environment-contract.json by scripts/generate-environment-artifacts.mjs.
# Never place real secrets in this committed file.
# Hosted CI resolves Terraform/provider values and generates temporary runtime configuration.

# ---------- Supabase ----------
# [required] [public] Supabase project API URL
NEXT_PUBLIC_SUPABASE_URL=
# [required] [public] Supabase publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# [required] [SECRET] Supabase server key or local service-role key
SUPABASE_SECRET_KEY=
# ---------- Supabase local OAuth ----------
# [optional] [public] Local Supabase Google OAuth client id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# [optional] [SECRET] Local Supabase Google OAuth client secret
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
# ---------- HitPay ----------
# [required] [SECRET] HitPay server-side business API key
HITPAY_API_KEY=
# [required] [SECRET] HitPay webhook HMAC salt
HITPAY_WEBHOOK_SALT=
# [required] [public] HitPay API base URL; use sandbox outside production
HITPAY_API_URL=https://api.sandbox.hit-pay.com
# [required] [public] Comma-separated HitPay online payment method codes
HITPAY_PAYMENT_METHODS=paynow_online
# ---------- Application ----------
# [required] [public] Canonical public URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# [required] [public] Display name
APP_NAME=Marketplace
# [required when TARGET_ENV=production] [public] Comma-separated admin email allowlist; admin access also requires an active staff record
ADMIN_EMAIL_ALLOWLIST=
# [optional] [public] Development and E2E-only fixture catalog flag; ignored in production
MARKETPLACE_PREVIEW_FIXTURES=false
# [required when TARGET_ENV=production] [SECRET] Bearer secret used by Vercel Cron to authenticate scheduled maintenance routes
CRON_SECRET=
# [required when TARGET_ENV=production] [SECRET] Bearer secret for authenticated synthetic operational probes
SYNTHETIC_MONITOR_SECRET=
# [required when TARGET_ENV=production] [SECRET] HTTPS destination for privacy-safe critical operational alerts
OPERATIONAL_ALERT_WEBHOOK_URL=
# [required when TARGET_ENV=production] [SECRET] HMAC secret used to sign operational alert deliveries
OPERATIONAL_ALERT_WEBHOOK_SECRET=
# ---------- Observability ----------
# [optional] [public] Sentry project DSN for browser, Node.js, and Edge telemetry
NEXT_PUBLIC_SENTRY_DSN=
# [optional] [public] Optional server-only Sentry DSN override
SENTRY_DSN=
# [optional] [public] Explicit Sentry environment name shared with browser telemetry
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# [optional] [public] Optional server-only Sentry environment override
SENTRY_ENVIRONMENT=
# [optional] [public] Browser performance trace sample rate from 0 to 1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# [optional] [public] Server and Edge performance trace sample rate from 0 to 1
SENTRY_TRACES_SAMPLE_RATE=
# [optional] [public] Browser session replay sample rate from 0 to 1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=
# [optional] [public] Browser error replay sample rate from 0 to 1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=
# [optional] [public] Optional explicit Sentry release identifier
SENTRY_RELEASE=
# [optional] [public] Sentry organization slug for release and source-map uploads
SENTRY_ORG=
# [optional] [public] Sentry project slug for release and source-map uploads
SENTRY_PROJECT=
# [optional] [SECRET] Scoped Sentry build token for release and source-map uploads
SENTRY_AUTH_TOKEN=
# ---------- Hosted deployment ----------
# [required] [public; deploy-time only] Deployment environment
TARGET_ENV=development
# [required] [public; deploy-time only] Whether hosted Google authentication must be configured
GOOGLE_AUTH_ENABLED=true
# [optional] [SECRET; deploy-time only] Supabase Management API and CLI access
SUPABASE_ACCESS_TOKEN=
# [optional] [SECRET; deploy-time only] Supabase database credential
SUPABASE_DB_PASSWORD=
# [optional] [public; deploy-time only] Supabase project reference
SUPABASE_PROJECT_REF=
# [required when GOOGLE_AUTH_ENABLED=true] [public; deploy-time only] Hosted Google OAuth client id
GOOGLE_OAUTH_CLIENT_ID=
# [required when GOOGLE_AUTH_ENABLED=true] [SECRET; deploy-time only] Hosted Google OAuth client secret
GOOGLE_OAUTH_CLIENT_SECRET=
# [optional] [public; deploy-time only] Registered HitPay webhook id
HITPAY_WEBHOOK_ID=
# [optional] [public; deploy-time only] HitPay webhook event override
HITPAY_WEBHOOK_ENABLED_EVENTS=
# [optional] [SECRET; deploy-time only] Vercel CLI access
VERCEL_TOKEN=
# [optional] [public; deploy-time only] Vercel user or team scope id
VERCEL_ORG_ID=
# [optional] [public; deploy-time only] Vercel project id
VERCEL_PROJECT_ID=
# ---------- Optional notifications ----------
# [optional] [SECRET] Email provider key
RESEND_API_KEY=
# [optional] [public] Verified sender email
RESEND_FROM_EMAIL=
# [required when TARGET_ENV=production] [public] Public support and data-protection contact email
SUPPORT_EMAIL=
# [optional] [public] Twilio account id
TWILIO_ACCOUNT_SID=
# [optional] [SECRET] Twilio authentication token
TWILIO_AUTH_TOKEN=
# [optional] [SECRET] Telegram bot token
TELEGRAM_BOT_TOKEN=
# [optional] [SECRET] WhatsApp access token
WHATSAPP_ACCESS_TOKEN=
# [optional] [public] WhatsApp phone number id
WHATSAPP_PHONE_NUMBER_ID=

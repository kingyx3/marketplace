# ============================================================
# Application environment contract
#
# NEVER put real secrets in this file. For deployed environments,
# CI resolves Terraform outputs, provider values, GitHub Environment vars,
# and secrets, then generates a temporary .env.deploy. The optional
# config/environments.json file is only a local fallback for stable defaults.
# Full table: docs/environments.md
#
# Legend:  [required|optional] [secret|public]
# ============================================================

# ---------- Supabase ----------
# [required] [public] Project API URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# [required] [public] Publishable key — safe for browsers, RLS-enforced
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# [required] [SECRET] Secret key — server-side only
SUPABASE_SECRET_KEY=
# [optional] [public] Google OAuth client ID for local Supabase Auth
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# [optional] [SECRET] Google OAuth client secret for local Supabase Auth
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# ---------- Stripe ----------
# [required] [public] pk_test_... in development, pk_live_... in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# [required] [SECRET] sk_test_... in development, sk_live_... in production
STRIPE_SECRET_KEY=
# [required] [SECRET] Signing secret of the webhook endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=

# ---------- App ----------
# [required] [public] Display name shown in app chrome, metadata, health, and emails
APP_NAME=Marketplace
# [required] [public] Canonical public URL of this environment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Deploy-time only (used by CI, never written to .env) ----------
# [required] [public] development | production; must match the GitHub Environment
TARGET_ENV=development
# [SECRET] Supabase CLI token for `supabase db push` and hosted Auth configuration
SUPABASE_ACCESS_TOKEN=
# [SECRET] Database password for `supabase link`; CI resolves this from Terraform output
SUPABASE_DB_PASSWORD=
# [public] Supabase project ref for `supabase link` and hosted Auth configuration; CI resolves this from Terraform output
SUPABASE_PROJECT_REF=
# [public] Hosted Supabase Auth Google provider client ID from Google Cloud; set as an environment var until OAuth client creation is automated
GOOGLE_OAUTH_CLIENT_ID=
# [SECRET] Hosted Supabase Auth Google provider client secret from Google Cloud
GOOGLE_OAUTH_CLIENT_SECRET=
# [optional] [public] Stripe webhook endpoint id (we_...) to bind automation to a specific endpoint; CI can resolve it when exactly one endpoint matches the site URL
STRIPE_WEBHOOK_ENDPOINT_ID=
# [optional] [public] Comma/space separated Stripe webhook event override; app defaults are versioned in config/environments.json
STRIPE_WEBHOOK_ENABLED_EVENTS=
# [SECRET] Vercel deploy token
VERCEL_TOKEN=
# [public] Vercel deploy scope id: personal user id on Hobby, team/org id if moved later; CI resolves this from Vercel when possible
VERCEL_ORG_ID=
# [public] Vercel project id; CI resolves this from Terraform output
VERCEL_PROJECT_ID=

# ---------- Notifications (all optional; missing key = channel disabled) ----------
# [optional] [SECRET] Email via Resend
RESEND_API_KEY=
# [optional] [public] Verified Resend sender address
RESEND_FROM_EMAIL=
# [optional] [public] Support contact shown in transactional emails
SUPPORT_EMAIL=
# [optional] [public] + [SECRET] SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# [optional] [SECRET] Telegram Bot API
TELEGRAM_BOT_TOKEN=
# [optional] [SECRET] WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
# [optional] [public] WhatsApp Cloud API sender phone-number id
WHATSAPP_PHONE_NUMBER_ID=

# Generated from config/environment-contract.json by scripts/generate-environment-artifacts.mjs.
# Never place real secrets in this committed file.
# Hosted CI resolves Terraform/provider values and generates temporary runtime configuration.

# ---------- Supabase ----------
# [required] [public] Supabase project API URL
NEXT_PUBLIC_SUPABASE_URL=
# [required] [public] Supabase publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# [required] [SECRET] Supabase server key or local service-role key
SUPABASE_SECRET_KEY=
# ---------- Supabase local OAuth ----------
# [optional] [public] Local Supabase Google OAuth client id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# [optional] [SECRET] Local Supabase Google OAuth client secret
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
# ---------- Stripe ----------
# [required] [public] Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# [required] [SECRET] Stripe server key
STRIPE_SECRET_KEY=
# [required] [SECRET] Stripe webhook signing key
STRIPE_WEBHOOK_SECRET=
# ---------- Application ----------
# [required] [public] Canonical public URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# [required] [public] Display name
APP_NAME=Marketplace
# [required when TARGET_ENV=production] [SECRET] Bearer secret used by Vercel Cron to authenticate scheduled maintenance routes
CRON_SECRET=
# ---------- Hosted deployment ----------
# [required] [public; deploy-time only] Deployment environment
TARGET_ENV=development
# [required] [public; deploy-time only] Whether hosted Google authentication must be configured
GOOGLE_AUTH_ENABLED=true
# [optional] [SECRET; deploy-time only] Supabase Management API and CLI access
SUPABASE_ACCESS_TOKEN=
# [optional] [SECRET; deploy-time only] Supabase database credential
SUPABASE_DB_PASSWORD=
# [optional] [public; deploy-time only] Supabase project reference
SUPABASE_PROJECT_REF=
# [required when GOOGLE_AUTH_ENABLED=true] [public; deploy-time only] Hosted Google OAuth client id
GOOGLE_OAUTH_CLIENT_ID=
# [required when GOOGLE_AUTH_ENABLED=true] [SECRET; deploy-time only] Hosted Google OAuth client secret
GOOGLE_OAUTH_CLIENT_SECRET=
# [optional] [public; deploy-time only] Managed Stripe webhook endpoint id
STRIPE_WEBHOOK_ENDPOINT_ID=
# [optional] [public; deploy-time only] Stripe webhook event override
STRIPE_WEBHOOK_ENABLED_EVENTS=
# [optional] [SECRET; deploy-time only] Vercel CLI access
VERCEL_TOKEN=
# [optional] [public; deploy-time only] Vercel user or team scope id
VERCEL_ORG_ID=
# [optional] [public; deploy-time only] Vercel project id
VERCEL_PROJECT_ID=
# ---------- Optional notifications ----------
# [optional] [SECRET] Email provider key
RESEND_API_KEY=
# [optional] [public] Verified sender email
RESEND_FROM_EMAIL=
# [optional] [public] Support email
SUPPORT_EMAIL=
# [optional] [public] Twilio account id
TWILIO_ACCOUNT_SID=
# [optional] [SECRET] Twilio authentication token
TWILIO_AUTH_TOKEN=
# [optional] [SECRET] Telegram bot token
TELEGRAM_BOT_TOKEN=
# [optional] [SECRET] WhatsApp access token
WHATSAPP_ACCESS_TOKEN=
# [optional] [public] WhatsApp phone number id
WHATSAPP_PHONE_NUMBER_ID=

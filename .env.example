# ============================================================
# Application environment contract
#
# NEVER put real values in this file. GitHub Environment secrets/vars
# are the source of truth for deployed environments. CI generates a
# temporary .env from those values, syncs runtime keys to Vercel, and
# never commits generated files. Full table: docs/environments.md
#
# Legend:  [required|optional] [secret|var]
# ============================================================

# ---------- Supabase ----------
# [required] [var] Project API URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# [required] [var] Publishable key — safe for browsers, RLS-enforced
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# [required] [SECRET] Secret key — server-side only
SUPABASE_SECRET_KEY=
# [optional] [var] Google OAuth client ID for local Supabase Auth
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# [optional] [SECRET] Google OAuth client secret for local Supabase Auth
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
# [optional] [var] Deprecated local Google OAuth client ID alias; prefer SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# [optional] [SECRET] Deprecated local Google OAuth client secret alias; prefer SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=

# ---------- Stripe ----------
# [required] [var] pk_test_... in development, pk_live_... in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# [required] [SECRET] sk_test_... in development, sk_live_... in production
STRIPE_SECRET_KEY=
# [required] [SECRET] Signing secret of the webhook endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=

# ---------- App ----------
# [required] [var] Display name shown in app chrome, metadata, health, and emails
APP_NAME=Marketplace
# [required] [var] Canonical public URL of this environment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Deploy-time only (used by CI, never written to .env) ----------
# [required] [var] development | production; must match the GitHub Environment
TARGET_ENV=development
# [SECRET] Supabase CLI token for `supabase db push` and hosted Auth configuration
SUPABASE_ACCESS_TOKEN=
# [SECRET] Database password for `supabase link`
SUPABASE_DB_PASSWORD=
# [var] Supabase project ref for `supabase link` and hosted Auth configuration
SUPABASE_PROJECT_REF=
# [var] Hosted Supabase Auth Google provider client ID from Google Cloud
GOOGLE_OAUTH_CLIENT_ID=
# [SECRET] Hosted Supabase Auth Google provider client secret from Google Cloud
GOOGLE_OAUTH_CLIENT_SECRET=
# [SECRET] Vercel deploy token
VERCEL_TOKEN=
# [var] Vercel org + project ids
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ---------- Notifications (all optional; missing key = channel disabled) ----------
# [optional] [SECRET] Email via Resend
RESEND_API_KEY=
# [optional] [var] Verified Resend sender address
RESEND_FROM_EMAIL=
# [optional] [var] Support contact shown in transactional emails
SUPPORT_EMAIL=
# [optional] [var] + [SECRET] SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# [optional] [SECRET] Telegram Bot API
TELEGRAM_BOT_TOKEN=
# [optional] [SECRET] WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
# [optional] [var] WhatsApp Cloud API sender phone-number id
WHATSAPP_PHONE_NUMBER_ID=

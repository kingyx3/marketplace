# ============================================================
# marketplace — environment contract
#
# NEVER put real values in this file. The real .env is generated by
# `node scripts/generate-env.mjs --write` (locally or in CI) from
# GitHub Environment secrets/vars. Full table: docs/environments.md
#
# Legend:  [required|optional] [secret|var]
# ============================================================

# ---------- Supabase ----------
# [required] [var] Project API URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# [required] [var] Anon/publishable key — safe for browsers, RLS-enforced
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [required] [SECRET] Service role key — bypasses RLS; server-side only
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Stripe ----------
# [required] [SECRET] sk_test_... in dev/staging, sk_live_... in production
STRIPE_SECRET_KEY=
# [required] [SECRET] Signing secret of the webhook endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=

# ---------- App ----------
# [required] [var] Canonical public URL of this environment
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Deploy-time only (used by CI, never written to .env) ----------
# [required] [var] development | staging | production; must match the GitHub Environment
TARGET_ENV=development
# [SECRET] Supabase CLI token for `supabase db push`
SUPABASE_ACCESS_TOKEN=
# [SECRET] Database password for `supabase link`
SUPABASE_DB_PASSWORD=
# [var] Supabase project ref for `supabase link`
SUPABASE_PROJECT_REF=
# [SECRET] Vercel deploy token
VERCEL_TOKEN=
# [var] Vercel org + project ids
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ---------- Notifications (all optional; missing key = channel disabled) ----------
# [optional] [SECRET] Email via Resend
RESEND_API_KEY=
# [optional] [var] + [SECRET] SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# [optional] [SECRET] Telegram Bot API
TELEGRAM_BOT_TOKEN=
# [optional] [SECRET] WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
